#include <stdio.h>
#include <string.h>
int main()
{
    char text[100], key[100];
    int i, len;
    printf("Enter Plain Text (CAPITAL letters): ");
    scanf("%s", text);
    printf("Enter Key: ");
    scanf("%s", key);
    len = strlen(key);
    for(i = 0; text[i] != '\0'; i++) {
        text[i] = ((text[i] - 'A') + (key[i % len] - 'A')) % 26 + 'A';
    }
    printf("Cipher Text: %s\n", text);
    return 0;
}
