#include <stdio.h>
#include <string.h>
int main() {
    char c[100];
    char map[] = "ETAOINSHRDLCUMWFGYPBVKJXQZ";
    int i;
    printf("Enter Ciphertext: ");
    scanf("%s", c);
    printf("Possible Plaintext:\n");
    for(i = 0; c[i] != '\0'; i++) {
        if(c[i] >= 'A' && c[i] <= 'Z')
            printf("%c", map[c[i] - 'A']);
        else
            printf("%c", c[i]);
    }
    return 0;
}
