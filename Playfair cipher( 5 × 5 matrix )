#include <stdio.h>
#include <math.h>
int main() {
    double log2Keys = 0.0;
    int i;
    // Compute log2(25!)
    for (i = 1; i <= 25; i++) {
        log2Keys += log2((double)i);
    }
    printf("Possible Playfair keys = 25!\n");
    printf("Approximate power of 2 = 2^%.2f\n", log2Keys);

    return 0;
}
